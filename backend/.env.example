# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://erp_user:erp_password@localhost:5432/factory_erp?schema=public"

# ─── Auth (generate with: openssl rand -hex 32) ────────────────────────────
JWT_ACCESS_SECRET="replace-with-64-char-random-string"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="replace-with-different-64-char-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── AI Analytics (optional — get key at console.anthropic.com) ───────────
ANTHROPIC_API_KEY=""

# ─── App ─────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CORS_ORIGIN="http://localhost:3000"
