# ─── Supabase Cloud Database Connection ───────────────────────────────
# Copy the URI connection string from Supabase settings (Database section)
# Replace [PASSWORD] with your database password.
DATABASE_URL="postgresql://postgres.[YOUR_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# ─── Auth Secrets (generate with: openssl rand -hex 32) ────────────────────────────
# Ensure these secrets match exactly on Vercel and in the desktop app
JWT_ACCESS_SECRET="generate-64-character-random-string-for-jwt-access"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="generate-different-64-character-random-string-for-jwt-refresh"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── AI Analytics (optional — get key at console.anthropic.com) ───────────
ANTHROPIC_API_KEY=""

# ─── App Config ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=production
CORS_ORIGIN="http://localhost:3000"
